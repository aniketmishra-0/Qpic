# AI vision tier (optional — improves detection on hard/scanned PDFs).
# Provider selection: "auto" (prefer OpenRouter when its key is set) | "openrouter" | "anthropic"
AI_PROVIDER=auto

# OpenRouter (OpenAI-compatible — lets you use Gemini/Qwen/Llama and free models)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# A vision-capable model id. A ":free" model works on a no-credit key; a paid
# one (e.g. google/gemini-3.5-flash) is more accurate.
OPENROUTER_MODEL=nvidia/nemotron-nano-12b-v2-vl:free
AI_MAX_TOKENS=1500

# Anthropic (alternative provider)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8

# PDF settings
PDF_RENDER_DPI=200
CROP_RENDER_DPI=400
QUESTION_PADDING_PX=20
MAX_PDF_SIZE_MB=50
MAX_PAGES=100

# Pipeline heuristic
MIN_QUESTIONS_PER_2_PAGES=0.5
# Mean OCR confidence (0-100) below which a page is escalated to the AI tier.
OCR_MIN_CONFIDENCE=75

# OCR languages passed to Tesseract. Combine scripts with "+". Use "eng+hin" for
# English + Hindi (Devanagari) papers — the right language is what lets OCR read
# the body text, so crops reach their true bottom instead of stopping short.
# Packs that aren't installed are skipped automatically. Install Hindi with:
#   macOS:   brew install tesseract-lang
#   Ubuntu:  apt install tesseract-ocr-hin
OCR_LANGUAGES=eng+hin

# AI batch settings (Tier 3 only)
AI_BATCH_SIZE=4
AI_BATCH_OVERLAP=1
AI_MAX_RETRIES=3

# Answer-sheet export: bundle an answers.csv + answers.json (cropped image ->
# correct option) into every download, read from the paper's own answer key.
# Set to false to turn the feature off.
ANSWER_SHEET_ENABLED=true

# Cleanup
TEMP_DIR=temp
CLEANUP_AFTER_SECONDS=1800

# OCR (Tesseract). Normally auto-detected (PATH / bundled copy / standard install
# locations). Set this only to force a specific binary, e.g.:
#   macOS:   /opt/homebrew/bin/tesseract
#   Windows: C:\Program Files\Tesseract-OCR\tesseract.exe
# TESSERACT_CMD=
